{
  "kind": "collectionType",
  "collectionName": "comments",
  "info": {
    "singularName": "comment",
    "pluralName": "comments",
    "displayName": "Comment"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "body": {
      "type": "blocks",
      "required": true
    },
    "commenter": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user",
      "inversedBy": "comments"
    },
    "question": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::comment.comment",
      "inversedBy": "comments"
    },
    "answer": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::answer.answer",
      "inversedBy": "comments"
    },
    "bot_answers": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::bot-answer.bot-answer"
    },
    "comments": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::comment.comment",
      "mappedBy": "question"
    },
    "votes": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::vote.vote",
      "mappedBy": "comment"
    }
  }
}
