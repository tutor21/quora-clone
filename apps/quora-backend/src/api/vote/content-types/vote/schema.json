{
  "kind": "collectionType",
  "collectionName": "votes",
  "info": {
    "singularName": "vote",
    "pluralName": "votes",
    "displayName": "Vote"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "type": {
      "type": "enumeration",
      "enum": [
        "upvote",
        "downvote"
      ]
    },
    "answer": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::answer.answer",
      "inversedBy": "votes"
    },
    "comment": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::comment.comment",
      "inversedBy": "votes"
    },
    "votes": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::vote.vote",
      "mappedBy": "bot_answer"
    },
    "bot_answer": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::vote.vote",
      "inversedBy": "votes"
    }
  }
}
